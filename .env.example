# Root-level env file consumed automatically by `docker compose` when running
# from this directory. Copy to `.env` and fill in the values you need.
#
# All variables here are OPTIONAL — without them, the stack still runs in
# Community-only mode and uses the defaults baked into docker-compose.yml.

# LocalStack Pro / Web App auth token.
# Required if you want to use the LocalStack Desktop / Web App Resource
# Browser (the rest of the app — S3 + SES — works without it).
# Get a free token at https://app.localstack.cloud → Account → Auth Tokens.
LOCALSTACK_AUTH_TOKEN=
