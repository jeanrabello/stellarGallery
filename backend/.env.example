# API
NODE_ENV=development
APP_PORT=3001
APP_HOST=0.0.0.0
APP_NAME=StellarGalleryAPI
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Mongo
MONGO_DB_NAME=stellarGallery
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root
MONGO_HOST=mongodb
MONGO_URI=mongodb://root:root@mongodb:27017/stellarGallery?authSource=admin

# Security
BCRYPT_SALT_ROUNDS=10

# JWT
JWT_SECRET=please-change-me
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=please-change-me-too
JWT_REFRESH_EXPIRES_IN=30d

# S3 / LocalStack
S3_ENDPOINT=http://localstack:4566
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_BUCKET=stellar-gallery
S3_PUBLIC_BASE_URL=http://localhost:4566/stellar-gallery
S3_FORCE_PATH_STYLE=true

# Google OAuth
# Set GOOGLE_CLIENT_ID to enable real id_token verification (google-auth-library).
# Leave it empty and keep GOOGLE_MOCK_ENABLED=true for the dev popup mock.
# GOOGLE_CLIENT_SECRET is NOT used by the current GIS popup flow — leave empty.
# It would only matter if we ever moved to the Authorization Code flow.
GOOGLE_MOCK_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (AWS SES via SESv2)
#
# Dev: pointing SES_ENDPOINT at LocalStack means messages never leave the
# stack — they're stored in moto's mailbox and visible via the LocalStack
# UI / `awslocal sesv2 list-suppressed-destinations`.
#
# Production: leave SES_ENDPOINT empty (the AWS SDK will use the real
# endpoint) and either drop SES_ACCESS_KEY_ID/SES_SECRET_ACCESS_KEY so the
# default provider chain (IAM role, ~/.aws, env) kicks in, or set them
# explicitly with an IAM user that has the `ses:SendEmail` permission.
#
# When EMAIL_ENABLED=false (or EMAIL_FROM/SES_REGION empty) the
# MockEmailService is used instead — logs to stdout and the invite link
# is still returned in the API response.
EMAIL_ENABLED=true
EMAIL_FROM=Stellar Gallery <no-reply@stellar-gallery.local>
SES_REGION=us-east-1
SES_ENDPOINT=http://localstack:4566
SES_ACCESS_KEY_ID=test
SES_SECRET_ACCESS_KEY=test
